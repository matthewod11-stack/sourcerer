{
  "name": "@sourcerer/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "sourcerer": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "dev": "node --watch dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@sourcerer/adapter-exa": "workspace:*",
    "@sourcerer/adapter-github": "workspace:*",
    "@sourcerer/ai": "workspace:*",
    "@sourcerer/core": "workspace:*",
    "@sourcerer/intake": "workspace:*",
    "@sourcerer/output-json": "workspace:*",
    "@sourcerer/output-markdown": "workspace:*",
    "@sourcerer/scoring": "workspace:*",
    "chalk": "^5.6.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
